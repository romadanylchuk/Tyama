{
  "expo": {
    "name": "Tyama",
    "slug": "tyama",
    "scheme": "tyama",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tyama.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.tyama.app"
    },
    "plugins": [
      "expo-sqlite",
      "expo-sharing",
      "expo-file-system",
      "expo-localization",
      "expo-status-bar"
    ],
    "experiments": {
      "baseUrl": "/Tyama"
    },
    "newArchEnabled": true
  }
}
